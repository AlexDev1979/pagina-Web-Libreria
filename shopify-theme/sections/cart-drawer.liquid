<section class="cart-drawer" aria-hidden="true" data-cart-drawer>
  <div class="cart-overlay" data-cart-overlay></div>
  <aside class="cart-panel" role="dialog" aria-modal="true" aria-labelledby="CartDrawer-Title">
    <header class="cart-header">
      <h2 id="CartDrawer-Title">{{ 'cart.title' | t }}</h2>
      <button type="button" class="cart-close" aria-label="{{ 'cart.close' | t }}" data-cart-close>×</button>
    </header>
    <div class="cart-body" data-cart-items>
      <!-- Items rendered by JS -->
    </div>

    {% if section.settings.upsell_collection != blank %}
      <div class="cart-upsell">
        <h3>{{ 'cart.upsell_heading' | t }}</h3>
        <ul class="upsell-grid">
          {% for product in section.settings.upsell_collection.products limit: section.settings.upsell_limit %}
            <li class="upsell-item">
              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}">
                {% endif %}
                <span class="title">{{ product.title }}</span>
              </a>
              <div class="price">{{ product.price | money }}</div>
              <form method="post" action="/cart/add" class="product-form upsell-form">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit">{{ 'products.product.add_to_cart' | t }}</button>
              </form>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <footer class="cart-footer">
      <div class="cart-subtotal">
        <span>{{ 'cart.subtotal' | t }}</span>
        <strong data-cart-subtotal>—</strong>
      </div>
      <div class="cart-note">
        <label for="CartNote">{{ 'cart.note_label' | t }}</label>
        <textarea id="CartNote" rows="2" placeholder="{{ 'cart.note_placeholder' | t }}" data-cart-note></textarea>
      </div>
      <div class="cart-discount">
        <label for="CartDiscount">{{ 'cart.discount_label' | t }}</label>
        <input id="CartDiscount" type="text" placeholder="{{ 'cart.discount_placeholder' | t }}" data-cart-discount>
        <small>{{ 'cart.discount_hint' | t }}</small>
      </div>
      <div class="cart-actions">
        <a href="{{ routes.cart_url }}" class="button button-outline">{{ 'cart.view_cart' | t }}</a>
        <form action="/checkout" method="post">
          <input type="hidden" name="discount" value="" data-discount-field>
          <button type="submit" class="button">{{ 'cart.checkout' | t }}</button>
        </form>
      </div>
    </footer>
  </aside>
</section>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    { "type": "collection", "id": "upsell_collection", "label": "Upsell collection" },
    { "type": "range", "id": "upsell_limit", "label": "Upsell products to show", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [ { "name": "Cart drawer" } ]
}
{% endschema %}