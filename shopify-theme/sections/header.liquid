<header class="site-header">
  <div class="container header-inner">
    <a href="{{ routes.root_url }}" class="site-logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" loading="eager">
      {% else %}
        <span class="site-title">{{ shop.name }}</span>
      {% endif %}
    </a>

    {% if section.settings.main_menu != blank %}
      <nav class="site-nav" role="navigation">
        <ul>
          {% for link in section.settings.main_menu.links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <button class="cart-button" data-cart-toggle aria-label="{{ 'cart.open' | t }}">
      <svg class="cart-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M6 6h15l-1.5 9h-13z" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="9" cy="20" r="1.5" fill="currentColor"/>
        <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
      </svg>
      <span class="cart-count-bubble" data-cart-count>0</span>
    </button>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "site-header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "main_menu", "label": "Main menu" }
  ],
  "presets": [ { "name": "Header" } ]
}
{% endschema %}