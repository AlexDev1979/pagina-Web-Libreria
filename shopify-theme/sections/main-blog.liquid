<section class="blog">
  <div class="container">
    <h1>{{ blog.title }}</h1>
    {% paginate blog.articles by 8 %}
      <ul class="grid">
        {% for article in blog.articles %}
          <li class="grid-item">
            <a href="{{ article.url }}" class="article-card">
              {% if article.image %}
                <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title }}">
              {% endif %}
              <h3>{{ article.title }}</h3>
              <p>{{ article.excerpt | default: article.content | strip_html | truncate: 120 }}</p>
            </a>
          </li>
        {% endfor %}
      </ul>
      {% if paginate.pages > 1 %}
        <nav class="pagination">
          {% if paginate.previous %}<a href="{{ paginate.previous.url }}">{{ 'general.pagination.previous' | t }}</a>{% endif %}
          <span>{{ paginate.current_page }} / {{ paginate.pages }}</span>
          {% if paginate.next %}<a href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }}</a>{% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": [],
  "presets": [ { "name": "Blog" } ]
}
{% endschema %}